/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

.bagua-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    #d4a853 20%, 
    #c41e3a 40%, 
    #7b2d8e 60%, 
    #d4a853 80%, 
    transparent 100%
  );
  opacity: 0.8;
}

.title-gold {
  display: block;
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.4);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.huiwen-divider {
  width: 200rpx;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #d4a853 0rpx,
    #d4a853 16rpx,
    transparent 16rpx,
    transparent 24rpx
  );
  opacity: 0.6;
  margin: 24rpx auto;
}

/* 内容区域 */
.content {
  padding: 20rpx 0;
}

/* 卡片样式 */
.card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4a853, transparent);
  opacity: 0.6;
}

.card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.card-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.card-desc {
  color: #b8b8d0;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 40rpx;
}

.footer-text {
  display: block;
  color: #6a6a8a;
  font-size: 20rpx;
  line-height: 1.8;
}
