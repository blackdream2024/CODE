/* pages/simulation/simulation.wxss */

.container {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

.bagua-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    #d4a853 20%, 
    #c41e3a 40%, 
    #7b2d8e 60%, 
    #d4a853 80%, 
    transparent 100%
  );
  opacity: 0.8;
}

.title-gold {
  display: block;
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.4);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.huiwen-divider {
  width: 200rpx;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #d4a853 0rpx,
    #d4a853 16rpx,
    transparent 16rpx,
    transparent 24rpx
  );
  opacity: 0.6;
  margin: 24rpx auto;
}

/* 配置区域 */
.config-section {
  margin-bottom: 40rpx;
}

.section-title {
  margin-bottom: 24rpx;
}

.section-title .title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #d4a853;
  font-size: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #d4a853 0%, #e6c07a 100%);
  color: #0a0a1a;
  font-weight: 600;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: rgba(212, 168, 83, 0.3);
  color: rgba(0, 0, 0, 0.5);
}

/* 结果区域 */
.result-section {
  padding: 20rpx 0;
}

/* 统计网格 */
.stat-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  display: block;
  color: #d4a853;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4a853, transparent);
  opacity: 0.6;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 风险网格 */
.risk-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.risk-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
}

.risk-label {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.risk-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.risk-high {
  color: #ff4d4f;
}

.risk-medium {
  color: #faad14;
}

.risk-low {
  color: #d4a853;
}

/* 总结文本 */
.summary-text {
  color: #b8b8d0;
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 决策列表 */
.decision-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.decision-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 20rpx;
}

.decision-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.decision-type {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.type-peak {
  background: rgba(82, 196, 26, 0.1);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
  color: #52c41a;
}

.type-low {
  background: rgba(255, 77, 79, 0.1);
  border: 1rpx solid rgba(255, 77, 79, 0.3);
  color: #ff4d4f;
}

.decision-time {
  color: #b8b8d0;
  font-size: 24rpx;
}

.decision-desc {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 建议列表 */
.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommendation-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.recommendation-index {
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 700;
  min-width: 40rpx;
}

.recommendation-text {
  color: #b8b8d0;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(212, 168, 83, 0.2);
  border-top-color: #d4a853;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: #b8b8d0;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
}
