/* pages/relation/relation.wxss */

.container {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

.bagua-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    #d4a853 20%, 
    #c41e3a 40%, 
    #7b2d8e 60%, 
    #d4a853 80%, 
    transparent 100%
  );
  opacity: 0.8;
}

.title-gold {
  display: block;
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.4);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.huiwen-divider {
  width: 200rpx;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #d4a853 0rpx,
    #d4a853 16rpx,
    transparent 16rpx,
    transparent 24rpx
  );
  opacity: 0.6;
  margin: 24rpx auto;
}

/* 命盘选择区域 */
.chart-selection {
  margin-bottom: 40rpx;
}

.section-title {
  margin-bottom: 24rpx;
}

.section-title .title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #d4a853;
  font-size: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #d4a853 0%, #e6c07a 100%);
  color: #0a0a1a;
  font-weight: 600;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: rgba(212, 168, 83, 0.3);
  color: rgba(0, 0, 0, 0.5);
}

/* 结果区域 */
.result-section {
  padding: 20rpx 0;
}

/* 评分卡片 */
.score-card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.score-title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

.score-value {
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
}

.score-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4a853, #e6c07a);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.score-desc {
  color: #b8b8d0;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 维度网格 */
.dimension-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.dimension-item {
  width: calc(50% - 8rpx);
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.dimension-name {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.dimension-value {
  display: block;
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4a853, transparent);
  opacity: 0.6;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 特征列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.feature-icon {
  color: #d4a853;
  font-size: 28rpx;
  margin-top: 4rpx;
}

.feature-text {
  color: #b8b8d0;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 风险列表 */
.risk-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.risk-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.risk-icon {
  color: #ff4d4f;
  font-size: 28rpx;
  margin-top: 4rpx;
}

.risk-text {
  color: #b8b8d0;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 建议列表 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.suggestion-index {
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 700;
  min-width: 40rpx;
}

.suggestion-text {
  color: #b8b8d0;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 大运网格 */
.dayun-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dayun-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 16rpx;
}

.dayun-period {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.dayun-desc {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 桃花网格 */
.taohua-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.taohua-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 16rpx;
}

.taohua-year {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.taohua-desc {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(212, 168, 83, 0.2);
  border-top-color: #d4a853;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: #b8b8d0;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
}
