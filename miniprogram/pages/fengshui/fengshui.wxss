/* pages/fengshui/fengshui.wxss */
.container {
  padding: 20rpx;
  background-color: #0a0a1a;
  min-height: 100vh;
}

/* 头部样式 */
.header {
  text-align: center;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #2a2a4a;
  margin-bottom: 30rpx;
}

.header-icon {
  font-size: 80rpx;
  color: #d4a853;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #d4a853;
  margin-bottom: 10rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: #b8b8d0;
}

/* 区域样式 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #d4a853;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #d4a853;
}

/* 位置信息样式 */
.location-card {
  background-color: #141430;
  border-radius: 20rpx;
  padding: 30rpx;
}

.location-info {
  margin-bottom: 20rpx;
}

.location-text {
  display: block;
  font-size: 28rpx;
  color: #b8b8d0;
  margin-bottom: 10rpx;
}

.location-empty {
  text-align: center;
  padding: 40rpx 0;
}

.location-hint {
  font-size: 28rpx;
  color: #b8b8d0;
}

.location-btn {
  width: 100%;
  background-color: #d4a853;
  color: #0a0a1a;
  font-weight: bold;
  border-radius: 10rpx;
}

/* 评分卡片样式 */
.score-card {
  background-color: #141430;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a853 0%, #f0d78c 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.score-number {
  font-size: 60rpx;
  font-weight: bold;
  color: #0a0a1a;
}

.score-label {
  font-size: 24rpx;
  color: #0a0a1a;
}

.score-details {
  width: 100%;
}

.score-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #2a2a4a;
}

.score-item-label {
  font-size: 28rpx;
  color: #b8b8d0;
}

.score-item-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #d4a853;
}

/* 方位分析样式 */
.direction-card {
  background-color: #141430;
  border-radius: 20rpx;
  padding: 30rpx;
}

.direction-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.direction-item {
  width: 48%;
  background-color: #1a1a3a;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.direction-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #d4a853;
  margin-bottom: 10rpx;
}

.direction-status {
  display: block;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  padding: 5rpx 10rpx;
  border-radius: 5rpx;
  text-align: center;
}

.direction-status.good {
  background-color: #1a3a1a;
  color: #4ade80;
}

.direction-status.bad {
  background-color: #3a1a1a;
  color: #f87171;
}

.direction-status.neutral {
  background-color: #3a3a1a;
  color: #fbbf24;
}

.direction-desc {
  display: block;
  font-size: 24rpx;
  color: #b8b8d0;
}

/* 建议样式 */
.advice-card {
  background-color: #141430;
  border-radius: 20rpx;
  padding: 30rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
}

.advice-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #2a2a4a;
}

.advice-item:last-child {
  border-bottom: none;
}

.advice-icon {
  width: 60rpx;
  height: 60rpx;
  background-color: #d4a853;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  font-size: 30rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #d4a853;
  margin-bottom: 10rpx;
}

.advice-text {
  display: block;
  font-size: 26rpx;
  color: #b8b8d0;
  line-height: 1.5;
}

/* 操作按钮样式 */
.action-buttons {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.action-btn {
  width: 100%;
  background-color: #d4a853;
  color: #0a0a1a;
  font-weight: bold;
  font-size: 32rpx;
  border-radius: 15rpx;
}

.action-btn[disabled] {
  background-color: #2a2a4a;
  color: #b8b8d0;
}