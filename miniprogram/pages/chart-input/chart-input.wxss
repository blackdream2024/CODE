/* pages/chart-input/chart-input.wxss */

.container {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

.bagua-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    #d4a853 20%, 
    #c41e3a 40%, 
    #7b2d8e 60%, 
    #d4a853 80%, 
    transparent 100%
  );
  opacity: 0.8;
}

.title-gold {
  display: block;
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.4);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.huiwen-divider {
  width: 200rpx;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #d4a853 0rpx,
    #d4a853 16rpx,
    transparent 16rpx,
    transparent 24rpx
  );
  opacity: 0.6;
  margin: 24rpx auto;
}

/* 表单区域 */
.form-container {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.form-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #d4a853;
  font-size: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #d4a853 0%, #e6c07a 100%);
  color: #0a0a1a;
  font-weight: 600;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: rgba(212, 168, 83, 0.3);
  color: rgba(0, 0, 0, 0.5);
}

/* 已录入命盘列表 */
.chart-list {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid rgba(212, 168, 83, 0.2);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title .title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

.section-title .count {
  color: #b8b8d0;
  font-size: 24rpx;
}

.chart-item {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-info {
  flex: 1;
}

.chart-name {
  display: block;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.chart-detail {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
}

.chart-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-btn.view {
  background: rgba(212, 168, 83, 0.1);
  border: 1rpx solid rgba(212, 168, 83, 0.3);
  color: #d4a853;
}

.action-btn.delete {
  background: rgba(196, 30, 58, 0.1);
  border: 1rpx solid rgba(196, 30, 58, 0.3);
  color: #c41e3a;
}
