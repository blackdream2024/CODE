/* pages/chart-view/chart-view.wxss */

.container {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
}

.bagua-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    #d4a853 20%, 
    #c41e3a 40%, 
    #7b2d8e 60%, 
    #d4a853 80%, 
    transparent 100%
  );
  opacity: 0.8;
}

.title-gold {
  display: block;
  color: #d4a853;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 168, 83, 0.4);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.huiwen-divider {
  width: 200rpx;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #d4a853 0rpx,
    #d4a853 16rpx,
    transparent 16rpx,
    transparent 24rpx
  );
  opacity: 0.6;
  margin: 24rpx auto;
}

/* 命盘选择区域 */
.chart-selector {
  margin-bottom: 32rpx;
}

.selector-label {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.selector-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #d4a853;
  font-size: 24rpx;
}

/* 命盘详情 */
.chart-detail {
  padding: 20rpx 0;
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4a853, transparent);
  opacity: 0.6;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  width: calc(50% - 8rpx);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 16rpx;
}

.info-label {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

/* 八字网格 */
.bazi-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.bazi-column {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 20rpx 12rpx;
}

.bazi-label {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.bazi-value {
  display: block;
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
}

/* 五行网格 */
.wuxing-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.wuxing-item {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 20rpx 12rpx;
}

.wuxing-element {
  display: block;
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.wuxing-strength {
  display: block;
  color: #ffffff;
  font-size: 24rpx;
}

/* 十神网格 */
.shishen-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.shishen-item {
  width: calc(33.33% - 8rpx);
  text-align: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 16rpx 8rpx;
}

.shishen-name {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.shishen-value {
  display: block;
  color: #d4a853;
  font-size: 28rpx;
  font-weight: 600;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-secondary {
  flex: 1;
  background: rgba(212, 168, 83, 0.1);
  border: 1rpx solid rgba(212, 168, 83, 0.3);
  color: #d4a853;
  font-weight: 600;
  font-size: 28rpx;
  border-radius: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-secondary::after {
  border: none;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #d4a853 0%, #e6c07a 100%);
  color: #0a0a1a;
  font-weight: 600;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-primary::after {
  border: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  color: #b8b8d0;
  font-size: 24rpx;
  margin-bottom: 40rpx;
}
