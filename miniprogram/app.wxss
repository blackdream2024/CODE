/* MingPanEngine 小程序全局样式 */

page {
  background-color: #0a0a1a;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
}

/* 卡片样式 */
.card {
  background: linear-gradient(135deg, #141430 0%, #1a1a3e 100%);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

/* 标题样式 */
.title {
  color: #d4a853;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #d4a853 0%, #e6c07a 100%);
  color: #0a0a1a;
  font-weight: 600;
  border-radius: 8rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 标签样式 */
.tag {
  background: rgba(212, 168, 83, 0.1);
  border: 1rpx solid rgba(212, 168, 83, 0.3);
  color: #d4a853;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 24rpx;
}

/* 输入框样式 */
.input {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  color: #ffffff;
  border-radius: 8rpx;
  padding: 16rpx;
}

/* 选择器样式 */
.picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 168, 83, 0.2);
  color: #ffffff;
  border-radius: 8rpx;
  padding: 16rpx;
}

/* 分割线样式 */
.divider {
  border-color: rgba(212, 168, 83, 0.2);
  margin: 16rpx 0;
}

/* 文字颜色 */
.text-gold {
  color: #d4a853;
}

.text-secondary {
  color: #b8b8d0;
}

.text-muted {
  color: #6a6a8a;
}

/* 背景颜色 */
.bg-dark {
  background-color: #0a0a1a;
}

.bg-card {
  background-color: #141430;
}

/* 弹性布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 间距 */
.mt-16 {
  margin-top: 16rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.mb-16 {
  margin-bottom: 16rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

.p-16 {
  padding: 16rpx;
}

.p-24 {
  padding: 24rpx;
}

/* 响应式字体 */
.text-xs {
  font-size: 20rpx;
}

.text-sm {
  font-size: 24rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}
